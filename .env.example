# Core service URLs
APP_BASE_URL=http://127.0.0.1:3000
KERNEL_BASE_URL=http://127.0.0.1:8787
HERMES_BASE_URL=http://127.0.0.1:8799
COMPANION_BASE_URL=http://127.0.0.1:8798
CONTACTWAY_MODE=buttplug_ws
CONTACTWAY_BRIDGE_URL=ws://127.0.0.1:12345
CONTACTWAY_ENABLED=false

# Public web client URLs
NEXT_PUBLIC_KERNEL_URL=http://127.0.0.1:8787
NEXT_PUBLIC_HERMES_URL=http://127.0.0.1:8799
NEXT_PUBLIC_COMPANION_URL=http://127.0.0.1:8798

# Operator auth
WEB_OPERATOR_TOKEN=

# Kernel/Hermes persistence
KERNEL_STATE_FILE=build/kernel/state.json
HERMES_RUNTIME_PORT=8799
HERMES_RUNTIME_STATE=build/hermes/runtime-state.json

# Voice companion
VOICE_TRANSCRIBE_MODE=local-whisper
VOICE_TRANSCRIBE_MODEL=Xenova/whisper-tiny.en
VOICE_TRANSCRIBE_DEVICE=cpu
VOICE_TRANSCRIBE_LANGUAGE=en
VOICE_TRANSCRIBE_COMMAND=
VOICE_TRANSCRIBE_ARGS=[]

# HyperCinema adapter
HYPERCINEMA_BASE_URL=https://your-hypercinema-deployment.web.app/
HYPERCINEMA_API_KEY=
HYPERCINEMA_DEFAULT_STYLE=hyperflow_assembly
HYPERCINEMA_DEFAULT_DURATION=1d
HYPERCINEMA_PAYMENT_ROUTE=sol_direct
